{
  "skill": "code-task",
  "checks": {
    "task-meta": {
      "required_fields": [
        "id",
        "type",
        "workflow",
        "status",
        "created_at",
        "updated_at",
        "agent_infra_version",
        "current_step",
        "assigned_to"
      ],
      "expected_step": "code"
    },
    "artifact": {
      "file_pattern": "code.md|code-r{N}.md",
      "required_sections": [
        "Modified Files",
        "Key Code Explanation",
        "Test Results",
        "Differences from Plan",
        "Items for Review",
        "State Check",
        "Evidence"
      ],
      "freshness_minutes": 30,
      "required_patterns": [
        "^\\$ "
      ]
    },
    "activity-log": {
      "expected_action_pattern": "(Code Task|Code) \\(Round \\d+(?:, fix for review-code(?:-r\\d+)?\\.md)?\\)",
      "freshness_minutes": 30
    },
    "platform-sync": {
      "when": "issue_number_exists",
      "expected_status_label": "status: in-progress",
      "expected_comment_marker": "<!-- sync-issue:{task-id}:{artifact-stem} -->",
      "verify_comment_content": true,
      "verify_task_comment_content": true,
      "verify_issue_type": true,
      "verify_issue_fields": false,
      "verify_milestone": true,
      "verify_milestone_specific": true,
      "expected_status_label_key": "inProgress",
      "expected_comment_marker_key": "artifact"
    }
  }
}
